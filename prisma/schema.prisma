generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProcessPriority {
  NORMAL
  HIGH
}

enum ProcessStatus {
  IN_PROGRESS
  DONE
}

enum UserRole {
  ADMIN
  OPERATOR
}

enum CaixaType {
  OCOM
  OCNO
  CIVA_AZ
}

enum OperatorLocation {
  SBCZ
  SBTF
  SBAT
  SBHT
  SBCJ
  SBIH
  SBMA
  SBTB
  SBJI
  SBUY
  SBRD
  SBSO
  SBSI
  SSKW
  SWGN
}

model Process {
  id            String          @id @default(uuid())
  sigad         String          @unique
  priority      ProcessPriority @default(NORMAL)
  subject       String
  status        ProcessStatus   @default(IN_PROGRESS)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deadline      DateTime?
  linkedProcess String?

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id])

  history ProcessHistory[]

  trackerId String?
  tracker   Tracker? @relation(fields: [trackerId], references: [id])

  tasks     ProcessTask[]
  todoTasks Task[]
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  role          UserRole @default(OPERATOR)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  processes        Process[]
  history          ProcessHistory[]
  ocomHistory      OcomHistory[]
  ocomChangeLog    OcomChangeLog[]
  sessions         Session[]
  accounts         Account[]
  responsibleTasks Task[]   @relation("TaskResponsible")
  createdTasks     Task[]   @relation("TaskCreator")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

model ProcessHistory {
  id    String  @id @default(uuid())
  text  String
  sigad String?

  processId String
  process   Process @relation(fields: [processId], references: [id], onDelete: Cascade)

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

model Tracker {
  id        String    @id @default(uuid())
  name      String    @unique
  caixa     CaixaType @default(OCNO)
  createdAt DateTime  @default(now())

  documentTemplateId String?
  documentTemplate   DocumentTemplate? @relation("TrackerTemplate", fields: [documentTemplateId], references: [id])

  tasks TrackerTask[]

  processes     Process[]
  ocomProcesses OcomProcess[]
}

model TrackerTask {
  id    String @id @default(uuid())
  title String
  order Int

  trackerId String
  tracker   Tracker @relation(fields: [trackerId], references: [id], onDelete: Cascade)

  documentTemplateId String?
  documentTemplate   DocumentTemplate? @relation("TrackerTaskTemplate", fields: [documentTemplateId], references: [id])

  processTasks     ProcessTask[]
  ocomProcessTasks OcomProcessTask[]

  @@unique([trackerId, order])
}

model ProcessTask {
  id String @id @default(uuid())

  processId String
  process   Process @relation(fields: [processId], references: [id], onDelete: Cascade)

  trackerTaskId String
  trackerTask   TrackerTask @relation(fields: [trackerTaskId], references: [id], onDelete: Cascade)

  done Boolean @default(false)

  @@unique([processId, trackerTaskId])
}

model OcomProcessTask {
  id            String      @id @default(uuid())
  ocomProcessId String
  ocomProcess   OcomProcess @relation(fields: [ocomProcessId], references: [id], onDelete: Cascade)
  trackerTaskId String
  trackerTask   TrackerTask @relation(fields: [trackerTaskId], references: [id], onDelete: Cascade)
  done          Boolean     @default(false)

  @@unique([ocomProcessId, trackerTaskId])
}

model OcomProcess {
  id               String    @id @default(uuid())
  processo         String
  categoria        String
  desigTelegrafica String
  localidade       String
  empresa          String?
  situacao         String    @default("EM ANDAMENTO")
  prazo            DateTime?
  anoInicio        Int
  observacoes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trackerId String?
  tracker   Tracker? @relation(fields: [trackerId], references: [id])

  history     OcomHistory[]
  tasks       OcomProcessTask[]
  changeLog   OcomChangeLog[]
}

model OcomChangeLog {
  id            String      @id @default(uuid())
  action        String
  field         String?
  oldValue      String?
  newValue      String?
  createdAt     DateTime    @default(now())

  ocomProcessId String
  ocomProcess   OcomProcess @relation(fields: [ocomProcessId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model OcomHistory {
  id        String @id @default(uuid())
  text      String
  estadoDoc String @default("Minuta")

  ocomProcessId String
  ocomProcess   OcomProcess @relation(fields: [ocomProcessId], references: [id], onDelete: Cascade)

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

model ApprovedUser {
  id        String      @id @default(uuid())
  email     String      @unique
  name      String
  role      UserRole    @default(OPERATOR)
  caixas    UserCaixa[]
  createdAt DateTime    @default(now())
}

model UserCaixa {
  id             String       @id @default(uuid())
  approvedUserId String
  approvedUser   ApprovedUser @relation(fields: [approvedUserId], references: [id], onDelete: Cascade)
  caixa          CaixaType

  @@unique([approvedUserId, caixa])
}

model Task {
  id        String          @id @default(uuid())
  text      String
  done      Boolean         @default(false)
  priority  ProcessPriority @default(NORMAL)
  deadline  DateTime?
  caixa     CaixaType       @default(OCNO)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  responsibleId String
  responsible   User   @relation("TaskResponsible", fields: [responsibleId], references: [id])

  creatorId String
  creator   User   @relation("TaskCreator", fields: [creatorId], references: [id])

  processId String?
  process   Process? @relation(fields: [processId], references: [id])
}

enum AdmAdGroup {
  DNB
  EPTA
  CIVA_AZ
}

model AdmAdContact {
  id                   String     @id @default(uuid())
  group                AdmAdGroup
  radio                String     @default("")
  oprOrgao             String     @default("")
  oprAd                String     @default("")
  horarioFuncionamento String     @default("")
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}

model OcomOperationalContact {
  id       String   @id @default(uuid())
  orgaoAts String
  tf2      String   @default("")
  tf4      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  location  OperatorLocation @id
  content   String           @default("")
  updatedAt DateTime         @updatedAt
}

model DocumentTemplate {
  id    String    @id @default(uuid())
  name  String    @unique
  text  String
  caixa CaixaType @default(OCNO)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trackers     Tracker[]     @relation("TrackerTemplate")
  trackerTasks TrackerTask[] @relation("TrackerTaskTemplate")
}
